        0.52 + 0.15,  // Uranus
        0.58 + 0.15,  // Neptune
        0.33 + 0.15,  // Asteroid Belt
        0.75 + 0.15   // Kuiper Belt
    );*/
    float orbitDist[10];
        orbitDist[0] = 0.15 + 0.15,  // Mercury
        orbitDist[1] = 0.19 + 0.15,  // Venus
        orbitDist[2] = 0.23 + 0.15,  // Earth
        orbitDist[3] = 0.28 + 0.15,  // Mars
        orbitDist[4] = 0.38 + 0.15,  // Jupiter
        orbitDist[5] = 0.45 + 0.15,  // Saturn
        orbitDist[6] = 0.52 + 0.15,  // Uranus
        orbitDist[7] = 0.58 + 0.15,  // Neptune
        orbitDist[8] = 0.33 + 0.15,  // Asteroid Belt
        orbitDist[9] = 0.75 + 0.15;   // Kuiper Belt

    /*float planetRadius[8] = float[](
        0076.90,  // Mercury
        0092.30,  // Venus
        0100.00,  // Earth
        0084.60,  // Mars
        1100.00,  // Jupiter
        0900.80,  // Saturn
        0400.20,  // Uranus
        0370.80   // Neptune
    );*/

    float planetRadius[8];
        planetRadius[0] = 76.90,  // Mercury
        planetRadius[1] = 92.30,  // Venus
        planetRadius[2] = 100.00,  // Earth
        planetRadius[3] = 84.60,  // Mars
        planetRadius[4] = 1100.00,  // Jupiter
        planetRadius[5] = 900.80,  // Saturn
        planetRadius[6] = 400.20,  // Uranus
        planetRadius[7] = 370.80;   // Neptune

    

    /*vec3 planetColors[8] = vec3[](
        vec3(0.6,  0.6,  0.7),  // Mercury (grey)
        vec3(0.9,  0.8,  0.5),  // Venus (pale yellowish)
        vec3(0.0,  0.4,  0.8),  // Earth (blue)
        vec3(0.8,  0.3,  0.3),  // Mars (reddish)
        vec3(0.9,  0.7,  0.5),  // Jupiter (beige-ish)
        vec3(0.9,  0.8,  0.6),  // Saturn (pale gold)
        vec3(0.6,  0.8,  0.800),  // Uranus (light cyan)
        vec3(0.208,0.518, 0.894)   // Neptune (blue)
    );*/
    vec3 planetColors[8];
        planetColors[0] = vec3(0.6,  0.6,  0.7),  // Mercury (grey)
        planetColors[1] = vec3(0.9,  0.8,  0.5),  // Venus (pale yellowish)
        planetColors[2] = vec3(0.0,  0.4,  0.8),  // Earth (blue)
        planetColors[3] = vec3(0.8,  0.3,  0.3),  // Mars (reddish)
        planetColors[4] = vec3(0.9,  0.7,  0.5),  // Jupiter (beige-ish)
        planetColors[5] = vec3(0.9,  0.8,  0.6),  // Saturn (pale gold)
        planetColors[6] = vec3(0.6,  0.8,  0.800),  // Uranus (light cyan)
        planetColors[7] = vec3(0.208,0.518, 0.894);   // Neptune (blue)
    
    /*float planetSpeeds[8] = float[](
        416.7,  // Mercury
        161.3,  // Venus
        100.0,  // Earth
        53.2,   // Mars
        8.43,   // Jupiter
        3.39,   // Saturn
        1.19,   // Uranus
        0.61    // Neptune
    );*/

    float planetSpeeds[8];
        planetSpeeds[0] = 416.7,  // Mercury
        planetSpeeds[1] = 161.3,  // Venus
        planetSpeeds[2] = 100.0,  // Earth
        planetSpeeds[3] = 53.2,   // Mars
        planetSpeeds[4] = 8.43,   // Jupiter
        planetSpeeds[5] = 3.39,   // Saturn
        planetSpeeds[6] = 1.19,   // Uranus
        planetSpeeds[7] = 0.61;    // Neptune
    
    
#if 1
    // base values used for scalling 
    float speed = 0.005 ;
    float baseplanetRadius = 0.0001;
    int asteroidCount = 200;

    float ringWidth = 0.0015 ; // width of the rotational axis ( planet orbits )
    
    // Draw rings ( orbits )
    for(int i = 0; i < 10; i++)
    {
        // Orbit ring
        float orbitMask = DrawRing(uv, vec2(0.0, 0.0), orbitDist[i], ringWidth);
        vec3 orbitColor = vec3(0.5);
        
        if (i==8){
            orbitMask = DrawAsteroidBelt(uv, vec2(0.0, 0.0), orbitDist[i],0.03,asteroidCount,0.0035, iTime);
            orbitColor = vec3(0.99);

        }
        
        col = mix(col, orbitColor, orbitMask);
    }
    
    // Draw Planets 
    for(int i =0 ; i < 8 ;i++){
        
        // Planets                                       
        float planetSpeed = speed * planetSpeeds[i];
        float size = baseplanetRadius * planetRadius[i];
        
        float angle = 3.14159 + iTime * planetSpeed;
        vec2 planetCenter = vec2(0.0) + orbitDist[i] * vec2(cos(angle), sin(angle));
        float planetMask = DrawCircle2(uv, planetCenter,size / 2.0);
        
        // Planet center is planetCenter
        // Sun at (0.0, 0.0)
        vec2 toSun2D  = -planetCenter; 
        float len     = length(toSun2D);
        vec3 lightDir = normalize(vec3(toSun2D, 0.0)); // embed in 3D as (x,y,0)

        
        vec3 planetCol = DrawCircle(uv, planetCenter, size / 2.0 , planetColors[i] , lightDir);
        //col = mix(col, planetCol, 1.0);    
                
        // Earth Logic its different cuz i wanted a ring around earth the represents the moon's orbit around earth 
        if ( i == 2 ) {
            float val = DrawEarth(uv, planetCenter, size / 2.0, ringWidth);
            if(val > 1.5)
            {
                col = mix(col, vec3(0.0, 0.4, 1.0), 1.0); // Blue planet
            }
            else if(val > 0.5)
            {
                col = mix(col, vec3(0.5),1.0); // White ring
            }
        }
        else{
            col = mix(col, planetCol, planetMask);
        }
    }
    
       // Sun 
    float lifeSizeFactor = 2.0;   /// sun is 25% of its size  for lifesize this factor should be 4.0
    float sunMask = DrawCircle2(uv, vec2(0.0, 0.0), 0.125 * lifeSizeFactor); 
    col = mix(col, vec3(1.0, 0.55, 0.0), sunMask);
    
    // Pulsating glow around the sun
    float dist = distance(uv, vec2(0.0, 0.0));
    float pulsation = 0.75 + 0.25 * sin(iTime * 1.0);
    float glowMask = 1.0 - smoothstep(0.25, 0.4, dist);
    col += glowMask * vec3(1.0, 0.8, 0.1) * 1.0 * pulsation;
    
    // Year calculations 
    // Year counter its set to match the time it takes earth to finish one rotation around the sun 
    // We take earths speed , find the current angle and every 2pi value increase equals to one year or one revolution around the sun
    float planetSpeed = 0.005 * planetSpeeds[2];
    float earthAngle = iTime * planetSpeed;
    float earthRevs = earthAngle / (6.28318); // 6.28318 = 2 * π
    myValue = int(floor(earthRevs));
    

    // Vignette effect
    float distFromCenter = length(uv);
    float radius   = 0.75;  // how far from center before it darkens
    float softness = 1.0;   // how gradually it transitions
    float vignette = smoothstep(radius - softness, radius, distFromCenter);
    
    col = mix(col, col * 0.3, vignette);
//    }
    
    uv *= scale;       // undo the scale i did in the top part for the main galaxy ( could also be a new uv value )
    
    
    // Digit scale and placement 
    float digitScale = 80.0;          
    vec2  basePos   = vec2(-1100.0,600.0);
    // add another 7-SEG display with 5 elements spelling YEAR-   final look => YEAR *blank space* - *blank space* myValue
    DrawYearLabel(uv, col, basePos, digitScale);
    
    basePos = vec2(-600.0,600);
    // for loop for 6 digits increase the counter if u want more 
    for(int dIndex = 0; dIndex < 6; dIndex++)
    {

        // Stop drawing after we drew all digits ( dIndex is 6 for drawing large numbers 
        // but we need to exit if our number is smaller than 6 digits
        // it still draws the 0 when the next number would require a new digit -> 099 , 0999 the 0 gets drawn
        if(dIndex > 0 && myValue < int(pow(10.0, float(dIndex)))){break;}

        int digit = getDigit(myValue, dIndex);

        vec2 digitCenterUV = basePos - vec2(float(dIndex) * 75.00, 0.0);
        vec2 p = (uv - digitCenterUV) / digitScale;

        // Draw the digit in the p-space
        float mask = DigitMask7Segment(p, digit);

        col = mix(col, vec3(1.0), mask);
    }

    col -= vec3(0.07);

//    col *= 10.;
    col *= 5.;

    fragColor = vec4(col, 1.0);   
#endif
    fragColor.a *= (fragColor.r+fragColor.g+fragColor.b)/3.;
//    fragColor.a *= fragColor.r+fragColor.g+fragColor.b > 0. ? 1. : 0.;
}

// MAIN ]

// ------------------------------------------ //

void main(void)
{
    mainImage(gl_FragColor, gl_FragCoord.xy);
//    gl_FragColor = vec4(1.);
}

