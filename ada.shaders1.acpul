// ------------------------------------------ //

precision highp float;

#define iTime CC_Time[0]*20.
#define iMouse vec2(0.)

uniform vec2 iResolution;
#define iResolution (iResolution*2.)

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec3 rxyy = vec3(iResolution.x, iResolution.y, iResolution.y);
    vec3 FC = vec3(fragCoord, 0.0);
    vec4 o = vec4(0.0);

    float i = 0.0, z = 0.0, d = 1.0, s = 0.0;

    for (i = 0.0; i++ < 100.0; o += vec4(0.2/d, 9.0, 2.0, 1.0) / d)
    {
        vec3 p = z * normalize(FC * 2.0 - rxyy), a = p;
        p.z += 7.0;
        s = length(p);

        for (d = 1.0; d <= 9.0; d++)
        {
            a += sin(a * d - iTime).yzx / d;
        }

        float sb = s - 4.0;
        z += d = length(vec4(
                 sin(s + s - iTime / 0.1 + a * sin(a.yzx / 3.0 + iTime)) + 0.9,
                 min(sb, -sb / 0.1) * 0.4)) * 0.1;
    }

    vec4 x = o / 8000.0;
    fragColor = (exp(2.0 * x) - 1.0) / (exp(2.0 * x) + 1.0);
}


// ------------------------------------------ //

void main(void)
{
    mainImage(gl_FragColor, gl_FragCoord.xy);
}

