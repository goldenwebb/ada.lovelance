### 29378:S dota.portal378

// https://www.shadertoy.com/view/332yRR

// Copyright
// 
// ------------------------------------------ //

precision highp float;

#define iTime CC_Time[0]*20.
#define iMouse vec2(0.)

uniform vec2 iResolution;
#define iResolution (iResolution*2.)

#define texture(a,b) vec4(0.)

float happy_star(vec2 uv, float anim)
{
    uv = abs(uv);
    vec2 pos = min(uv.xy/uv.yx, anim);
    float p = (2.0 - pos.x - pos.y);
    return (2.0+p*(p*p-1.5)) / (uv.x+uv.y);      
}
 
void mainImage(out vec4 fragColor, in vec2 fragCoord) {
    vec2 uv = (fragCoord * 2.0 - iResolution.xy) / iResolution.y;
    vec2 uv2 = ( fragCoord - .5*iResolution.xy ) / iResolution.y;
    float time = iTime * 0.8;
       uv = vec2(atan(uv.y,uv.x), log(length(uv)));
  uv.x = sin(uv.x*6.)/12.;
    // 创建深色背景
    vec3 bg = vec3(0.05, 0.05, 0.1);
    
    // 创建流动的光带
    vec3 color = bg;
    
    
    
     float ss=0.,s=0.,st=1./4.;
    for(float z=0.; z<1.; z+=st) {
    for(float y=0.; y<1.; y+=st) {
    for(float x=0.; x<1.; x+=st) {
    
         s = 2.+4.*texture(iChannel0, vec2(x*y*z,.0)).r;
         }}}
    // 主光带 - 使用更优雅的曲线
    for(int i = 0; i < 12; i++) {
        float fi = float(i);
        float t = time * 0.6 + fi * 12.0;
        
        // 创建平滑的曲线运动
        vec2 curve = vec2(
            sin(t + uv.y * 4.0) * 0.2,
            cos(t * 1.3 + uv.x * 2.0) *s
        );
        
        // 计算距离并创建光带
        float dist = length(uv - curve);
        float band = 0.02 / (dist + 0.01)*s;
        
        // 优雅的色彩
        vec3 bandColor = vec3(
            0.2 + 0.3 * sin(t + fi * 2.0),
            0.6 + 0.4 * cos(t * 1.2 + fi),
            0.8 + 0.2 * sin(t * 0.8 + fi * 1.5)
        );
        
        color += bandColor * band * 0.3;
    }
    
    // 添加旋转粒子
    for(int i = 0; i < 42; i++) {
        float fi = float(i);
        float radius = 0.2 + sin(time * 0.2 + fi) * 0.5;
        float angle = time * 1.5 + fi * 0.22;
        
        vec2 particlePos = vec2(
            cos(angle* 1.2) * radius,
            sin(angle * 1.2) * radius * 0.7
        );
        
        float particle = 0.0125 / (length(uv - particlePos) + 0.005);
        vec3 particleColor = vec3(
            0.9 + 0.1 * sin(fi * 1.0 + time),
            0.8 + 0.2 * cos(fi * 1.0 + time * 1.3),
            1.0
        );
        
        color += particleColor * particle * 0.2*s;
    }
    
    // 中心光晕
    float centerGlow = 0.08 / (length(uv) + 0.1);
    color += vec3(0.4, 0.3, 0.8) * centerGlow * 0.4;
    
    // 添加背景星光
    for(int i = 0; i < 15; i++) {
        float fi = float(i);
        vec2 starPos = vec2(
            sin(fi * 234.5) * 1.2,
            cos(fi * 567.8) * 1.2
        );
        
        float twinkle = sin(time * 2.0 + fi * 8.0) * 0.5 + 0.5;
        float star = 0.01 / (length(uv - starPos) + 0.01);
        
        color += vec3(1.0, 1.0, 1.0) * star * twinkle * 0.1;
    }
    
    // 色彩增强
    color = pow(color, vec3(1.1));
    
    // 添加微妙的整体脉动
    float pulse = sin(time * 0.3) * 0.05 + 0.95;
    color *= pulse;
    
    fragColor = vec4(color, 1.0);
    

    float anim = sin(iTime * 12.0) * 0.1 + 1.0;  // anim between 0.9 - 1.1 
    fragColor+= vec4(happy_star(uv2, anim*s) * vec3(0.4,0.4,0.45)*0.04, 1.0);
}

// ------------------------------------------ //

void main(void)
{
    mainImage(gl_FragColor, gl_FragCoord.xy);
//    gl_FragColor=vec4(1.);
}


