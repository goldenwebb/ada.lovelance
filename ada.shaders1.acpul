// https://www.shadertoy.com/view/XXyyzy

// Copyright
// 
// ------------------------------------------ //

precision highp float;

#define iTime CC_Time[0]*20.
#define iMouse vec2(0.)

uniform vec2 iResolution;
#define iResolution (iResolution*2.)

//_ @palletes0;
//uniform sampler2D iChannel0;
//uniform vec4 color0;
//uniform float value0;
//#define texture(a,b) texture2D(a,b)

// COMMON [

// Hash for stars
float rand(vec2 st) {
    return fract(sin(dot(st, vec2(12.9898, 78.233))) * 43758.5453123);
}

// TO-DO fix planets drawing make them more 3D 

float DrawCircle2(vec2 uv, vec2 center, float radius)
{
    float dist = distance(uv, center);
    return 1.0 - smoothstep(radius - 0.002, radius + 0.002, dist);
} 


// A modified DrawCircle that takes:
//   uv, planetCenter, radius,
//   planetColor, and the precomputed lightDir
vec3 DrawCircle(
    vec2 uv, 
    vec2 planetCenter, 
    float radius,
    vec3  planetColor,
    vec3  lightDir
){
    // 1) Smooth edge circle mask (soft boundary)
    float dist = distance(uv, planetCenter);
    float edge = 0.002; // small fade
    float mask = 1.0 - smoothstep(radius - edge, radius + edge, dist);
    if(mask <= 0.0)
    {
        // Outside the circle => no color
        return vec3(0.0);
    }

    // 2) "Fake sphere" normal for shading
    //    localP in [-1..+1]
    vec2 localP = (uv - planetCenter) / radius;
    float distSq = dot(localP, localP);

    float z = sqrt(1.0 - distSq); // "bulge" out of screen

    vec3 normal = normalize(vec3(localP, z));

    float diff = max(dot(normal, lightDir), 0.3);

    float ambient = 0.3;
    vec3 shadedCol = planetColor * (ambient + diff * (1.0 - ambient));

    // 5) Apply the circle mask so edges fade out
    return shadedCol * mask;
}



float DrawRing2(vec2 uv, vec2 center, float radius, float ringWidth)
{
    float dist  = distance(uv, center);
    float delta = abs(dist - radius);
    return 1.0 - step(ringWidth, delta);
}
float DrawRing(vec2 uv, vec2 center, float radius, float ringWidth)
{
    float dist = distance(uv, center);
    
    float inner = radius - ringWidth * 0.5;
    float outer = radius + ringWidth * 0.5;
    
    float inEdge  = smoothstep(inner - 0.002, inner + 0.002, dist);
    float outEdge = smoothstep(outer - 0.002, outer + 0.002, dist);

    return inEdge - outEdge;
}


// TO-DO avoid using the for loop try making a random hash that doesnt need to loop around every element ( saves tons of fps )

float DrawAsteroidBelt(vec2 uv, vec2 center, float radius, float width, int count, float astSize, float time)
{
    float beltMask = 0.0;
    float speed = 0.025;


    //    Quick distance check (early-out)
    //    If this pixel is outside the belt's radial region,
    //    there's no chance an asteroid is here.             ChadGPT iq 200 move
    float d      = distance(uv, center);
    float rMin   = radius - 0.5 * width - astSize;
    float rMax   = radius + 0.5 * width + astSize;
    if(d < rMin || d > rMax) {
        return 0.0; // no need to loop over asteroids
    }

    for(int i = 0; i < count; i++)
    {
        float baseAngle = 6.28318 * float(i) / float(count);
        float randAngle = rand(vec2(i, 0.123)) * 6.28318;
        float angle     = baseAngle + randAngle + time * speed;
        float rMin   = radius - 0.5 * width;
        float rRange = width;
        float rRand  = rMin + rRange * rand(vec2(i, 0.789));

        vec2 asteroidPos = center + rRand * vec2(cos(angle), sin(angle));
        float asteroidMask = DrawCircle2(uv, asteroidPos, astSize);

        beltMask = max(beltMask, asteroidMask);
    }

    return clamp(beltMask, 0.0, 1.0);
}

// Draw the moon's orbit to Earth 
float DrawEarth(vec2 uv, vec2 center, float radius, float ringWidth)
{
    float circleMask = DrawCircle2(uv, center, radius);      // 1.0 inside planet
    float ringMask   = DrawRing(uv, center, radius * 3.0, ringWidth); // 1.0 in ring

    float combined = circleMask * 2.0 + ringMask;     // planet adds 2, ring adds 1
    combined = min(combined, 2.0);                    // clamp so it never exceeds 2.0

    return combined; // [0..2]
}


// Drawing small stars at random positions with varying sizes and a pulse like effect periodically for each star
float starField(vec2 st,float time)
{
    vec2 i = floor(st);
    vec2 f = fract(st);
    float rnd = rand(i);    // spliting into fields and asigning an i value to each field 

    float threshold = 0.935;
    float val = 0.0;

    // if its greater than our threshold draw a star
    if(rnd > threshold)
    {
        float starSize = mix(0.05, 0.45, rand(i + 13.1234));
        float d        = length(f - 0.5);
        val            = 1.0 - smoothstep(0.0, starSize, d);

        // Add a periodic glow (pulsation) based on iTime
        float phaseOffset = rand(i + 73.24) * 6.28318;   // random phase per star
        float frequency   = 3.0;                         // how fast it pulses
        float starPulse   = 0.5 + 0.5 * sin(time * frequency + phaseOffset);
        val *= starPulse * 1.0;
    }

    return val;
}
mat2 rotate2D(float angle)
{
    float c = cos(angle);
    float s = sin(angle);
    return mat2(c,-s,s,c);
}

// Sdf for one element of our 7-seg display ( 1 rectangle ) returns 1 if our point is inside 
float RectMask(vec2 p, vec2 center, vec2 size)
{
    vec2 halfSize = size * 0.5;
    vec2 d = abs(p - center);
    return step(d.x, halfSize.x) * step(d.y, halfSize.y);
}

float DiagonalRectMask(vec2 p, vec2 center, vec2 size, float angle)
{
    vec2 shifted = p - center;

    mat2 R = rotate2D(-angle);
    vec2 local = R * shifted;

    vec2 halfSize = 0.5 * size;

    float inBoundsX = step(abs(local.x), halfSize.x);
    float inBoundsY = step(abs(local.y), halfSize.y);

    return inBoundsX * inBoundsY; // => 1.0 if inside, 0.0 if outside
}


//    A basic 7-segment digit SDF. 
//    p is local coords (e.g. in [-1..+1] range).
//    digit in [0..9].
float DigitMask7Segment(vec2 p, int digit)
{
    // Segment layout (assuming p.y is up):
    //      --A--
    //     |     |
    //     F     B
    //      --G--
    //     |     |
    //     E     C
    //      --D--
    //
    // We'll define each segment as a small rectangle:
    //   A: center=(0, +0.65), size=(0.5, 0.1)
    //   B: center=(+0.25, +0.4), size=(0.1, 0.4)
    //   C: center=(+0.25, -0.4), size=(0.1, 0.4)
    //   D: center=(0, -0.65), size=(0.5, 0.1)
    //   E: center=(-0.25, -0.4), size=(0.1, 0.4)
    //   F: center=(-0.25, +0.4), size=(0.1, 0.4)
    //   G: center=(0, 0.0), size=(0.5, 0.1)

    float segA = RectMask(p, vec2( 0.0,  0.65), vec2(0.5, 0.1));
    float segB = RectMask(p, vec2( 0.25, 0.35), vec2(0.1, 0.5));
    float segC = RectMask(p, vec2( 0.25,-0.25), vec2(0.1, 0.5));
    float segD = RectMask(p, vec2( 0.0, -0.55), vec2(0.5, 0.1));
    float segE = RectMask(p, vec2(-0.25,-0.25), vec2(0.1, 0.5));
    float segF = RectMask(p, vec2(-0.25, 0.35), vec2(0.1, 0.5));
    float segG = RectMask(p, vec2( 0.0,  0.05 ), vec2(0.5, 0.1));

    // For each digit, specify which segments are ON (1) or OFF (0).
    // We'll create a mask by OR'ing the necessary segments.
    float mask = 0.0;

    if(digit == 0) mask = segA + segB + segC + segD + segE + segF;            // 0
    if(digit == 1) mask = segB + segC;                                        // 1
    if(digit == 2) mask = segA + segB + segG + segE + segD;                   // 2
    if(digit == 3) mask = segA + segB + segC + segD + segG;                   // 3
    if(digit == 4) mask = segF + segG + segB + segC;                          // 4
    if(digit == 5) mask = segA + segF + segG + segC + segD;                   // 5
    if(digit == 6) mask = segA + segF + segE + segD + segC + segG;            // 6
    if(digit == 7) mask = segA + segB + segC;                                 // 7
    if(digit == 8) mask = segA + segB + segC + segD + segE + segF + segG;     // 8
    if(digit == 9) mask = segA + segB + segC + segD + segF + segG;            // 9

    // 'mask' can exceed 1.0 if multiple segments overlap a pixel; clamp it
    return clamp(mask, 0.0, 1.0);
}
float CharMask7Segment(vec2 p, int c)
{
    // segments
    float segA = RectMask(p, vec2( 0.00, 0.600), vec2(0.5, 0.1));
    float segB = RectMask(p, vec2( 0.25, 0.325), vec2(0.1, 0.5));
    float segC = RectMask(p, vec2( 0.25,-0.325), vec2(0.1, 0.5));
    float segD = RectMask(p, vec2( 0.00,-0.600), vec2(0.5, 0.1));
    float segE = RectMask(p, vec2(-0.25,-0.325), vec2(0.1, 0.5));
    float segF = RectMask(p, vec2(-0.25, 0.325), vec2(0.1, 0.5));
    float segG = RectMask(p, vec2( 0.00, 0.000), vec2(0.5, 0.1));
    float segH = DiagonalRectMask(p, vec2( 0.075,-0.33), vec2(0.66, 0.1) , radians(40.0)); // diagonal seg for R

    float mask = 0.0;

    if(c == 89) {  // Y
        mask = segB + segC + segD + segF + segG; 
    }
    else if(c == 69) { // E
        mask = segA + segF + segG + segE + segD;
    }
    else if(c == 65) { // A 
        mask = segA + segB + segF + segG + segC + segE;
    }
    else if(c == 82) { // R 
        mask = segA + segB + segF + segG + segE + segH; 
    }
    else if(c == 45) { // -
        mask = segG;
    }
    // else: no segments lit

    return clamp(mask, 0.0, 1.0);
}

void DrawYearLabel(vec2 uv, inout vec3 col, vec2 basePos, float digitScale)
{
    // We'll simulate a "string" => "YEAR-"
    // (In pure GLSL, you might need a workaround, but let's do conceptual code)
/*    int word[5] = int[](
        89, // 'Y'
        69, // 'E'
        65, // 'A'
        82, // 'R'
        45  // '-'
    );*/

    int word[5];
    word[0] = 89, // 'Y'
        word[1] = 69, // 'E'
        word[2] = 65, // 'A'
        word[3] = 82, // 'R'
        word[4] = 45;  // '-'
    for(int i=0; i<5; i++)
    {
        vec2 charPos = basePos + vec2(float(i)*75.0, 0.0);
        vec2 p       = (uv - charPos) / digitScale;
        float mask   = CharMask7Segment(p, word[i]);

        col = mix(col, vec3(1.0), mask);
    }
}


// Helper to get a digit from an integer, right-to-left
int getDigit(int value, int digitIndex)
{
    // E.g. if value=123, digitIndex=0 => returns 3, digitIndex=1 => returns 2, etc.
    for(int i=0; i<digitIndex; i++) { value /= 10; }
//    return value % 10;
    return int(mod(float(value), 10.));
}

// COMMON ]
// MAIN [

void mainImage( out vec4 fragColor, in vec2 fragCoord )
{
    // making it square 
    vec2 uv = fragCoord - 0.5 * iResolution.xy;
    float scale = min(iResolution.x, iResolution.y)/1.5; // SCALE 1.5!
    uv /= scale; 
    vec3 col = vec3(0.07, 0.0, 0.2); // purple background
    int myValue = 0;

    
//    if (true){ // did this for testing the number u can set it to false to enable or disable the galaxy 
    
    // Stars
    float starDensity = 250.0;
    float starVal = starField(uv * starDensity, iTime);
    col += starVal * vec3(2.0);
    
 
   
    // Other 8 planets values        all sizes , speeds , and distances here represent real life values just scalled down ( except the sun its explained above)
    /*float orbitDist[10] = float[](
        0.15 + 0.15,  // Mercury
        0.19 + 0.15,  // Venus
        0.23 + 0.15,  // Earth
        0.28 + 0.15,  // Mars
