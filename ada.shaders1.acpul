### 29412:S music412

// https://www.shadertoy.com/view/wXSyzG

// Copyright
// 
// ------------------------------------------ //

precision highp float;

#define iTime CC_Time[0]*20.
#define iMouse vec2(0.)

uniform vec2 iResolution;
#define iResolution (iResolution*2.)

#define texture(a,b) vec4(sin(b.x),sin(b.y),0.,1.)
#define texelFetch(a,b,c) vec4(sin(float(b.x)*iTime ))

uniform sampler2D iChannel0;

// Matriz de rotação
mat2 Rot(float a) {
    float s = sin(a), c = cos(a);
    return mat2(c, -s, s, c);
}

// Random number generator (between 1 and 0)
float rand(float seed) {
    seed = fract(seed + .500009);
    return fract(sin(seed * 1000.) * seed * 100.);
}

// Rectangle SDF (axis-aligned box)
// p : position, b : Rect. dimensions (half-extents)
float sdBox(vec2 p, vec2 b) {
    vec2 d = abs(p) - b;
    vec2 maxd = max(d, vec2(0.0));
    return length(maxd) + min(max(d.x, d.y), 0.0);
}

// Function to create Star
float Star(vec2 uv, float flare, float radius) {
    float pi = 3.14159265;
    float d = length(uv) > 0. ? length(uv) : 0.0001;
    
    float edgeAA = 0.005; // ajuste para suavidade da borda (em unidades UV)
    float insideMask = 1.0 - smoothstep(radius - 0.09 - edgeAA, radius - 0.09 + edgeAA, d);
    
    // Star center (circle)
    float m = 0.001/d;
    
    // Star Rays (Reactive to sound)
    float rays = 0.0;
    rays = max(0.0, 1.0-abs(uv.x*uv.y*(0.45-radius)*20000.0));
    
    m += rays*flare;
    
    uv *= Rot(pi/4.0);
    
    return m * insideMask;
}

// Function to create Triangle
float Trianle(vec2 p, float r)
{
    float k = sqrt(3.0);
    p.x = abs(p.x) - r;
    p.y = p.y + r/k;
    if (p.x + k*p.y > 0.0) p = vec2((p.x - k*p.y)/2.0, (-k*p.x - p.y)/2.0);
    p.x -= clamp(p.x, -2.0*r, 0.0);
    return -length(p)*sign(p.y);
}


// Low Pass Filter
float lowPass(float fft_entrance) {
    float lp = 0.0;
    for (int i = 0; i < 128; i++) {
        lp += fft_entrance * smoothstep(0.0, 0.5, float(i)/64.0);
    }
    lp /= 128.0;
    return lp;
}

void mainImage( out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = fragCoord.xy / iResolution.xy;
    uv -= 0.5;
    uv.x *= iResolution.x / iResolution.y;
    
    // Pi const
    float pi = 3.14159265;

    // Color palette (https://iquilezles.org/articles/palettes)
    vec3 A = vec3(0.5, 0.5, 0.5);
    vec3 B = vec3(0.6, 0.6, 0.6);
    vec3 C = vec3(2.0, 1.0, 1.0);
    vec3 D = vec3(0.00, 1.5, 3.0);
    vec3 color = A + B*cos(2.0*pi*(C*(iTime*0.2) + D));
    
    float fft = texelFetch(iChannel0, ivec2(uv.x, 0), 0).x;
    float lp = lowPass(fft);   // Audio filter
    float radius = clamp(0.35 * lp, 0.2, 0.3);
    
    // Camera shake
    uv.x += lp*0.06;
    uv.y += lp*0.06;
    
    // Circle
    fragColor = vec4(0.0);
    float fx, f;
    for (int i=0; i<5; i++) {
        fx = sin(abs(length(uv) - radius)) * 0.5 + 0.015;
        f = abs(uv.y - fx);
        fragColor += vec4(color, 1.0) * 0.005 / fx;
    }
    
    // Rectangles
    float recGirth = 0.008;
    vec3 bg = vec3(0.00);
    float numRet = 70.0;
    float numRays = 10.0;
    float angVar = 2.0*pi/numRet; // radians
    vec2 uv_copy = uv;
    float copyGirth = recGirth;
    for (float i=0.0; i<numRet; i++) {   
        recGirth *= clamp(rand(iTime/(i*lp*lp)), 0.85, 1.0);
        
        // Rotation Matrix
        uv *= Rot(angVar*i);

        fft = texelFetch(iChannel0, ivec2(i, 0.3), 0).x;
        lp = lowPass(fft);
        
        float recExt = 0.11 * lp;
        float offset = radius + 0.03;
        uv.x += (offset + recExt);
        
        float d = sdBox(uv, vec2(recExt, recGirth));
        
        float rect = step(abs(uv.x), recExt) * step(abs(uv.y), recGirth);
        float glow = exp(-abs(d) * 600.0);
        float edge = smoothstep(0.001, 0.0, abs(d));
        
        vec3 neon = color * (glow * 1.2 + edge * 1.5);

        vec3 rectColor = color * rect;
     
        vec3 outColor = mix(bg, rectColor, rect);
        fragColor += vec4(outColor + neon, 1.0);
        uv = uv_copy;   // Go to center
        recGirth = copyGirth;
    }
    
    // Star in Center (Reactive to sound)
    vec3 col = vec3(0.0);
    col += Star(uv, 1.0, radius);
    fragColor += vec4(col, 1.0);
    
    // Big Triangles
    float numTri = 2.0;
    float offset = radius + 0.3;
    uv_copy = uv;
    uv.x += offset;
    uv.y += 0.05;
    for (float i=0.0; i<numTri; i++){
        col = vec3(0.0);
        
        //col += Star(uv, 1.0, radius);
        float d = Trianle(uv, radius*0.6);
        float tri = smoothstep(0.01, 0.0, d);
        vec3 col = vec3(color * tri) * 0.07;
        
        fragColor += vec4(col, 1.0);
        uv.x -= 2.0*offset;
    }
    uv = uv_copy;
    
    // Small Triangles
    offset = radius + 0.5;
    uv_copy = uv;
    uv.x += offset;
    uv.y += 0.01;
    for (float i=0.0; i<numTri; i++){
        col = vec3(0.0);
        
        //col += Star(uv, 1.0, radius);
        float d = Trianle(uv, radius*0.3);
        float tri = smoothstep(0.01, 0.0, d);
        vec3 col = vec3(color * tri) * 0.07;
        
        fragColor += vec4(col, 1.0);
        uv.x -= 2.0*offset;
    }
    uv_copy = uv;
    
    // Interesting effect
    //fragColor *= vec4(color*(1. - rand(lp/float(5*iFrame))), 1.0);


    vec3 cc = fragColor.rgb;

    fragColor.rgb -= vec3(0.2);
    fragColor.rgb += 0.2 * cc * fragColor.rgb;
//    fragColor.rgb = min(vec3(0.), fragColor.rgb - vec3(0.1));

    fragColor.a = fragColor.r+fragColor.g+fragColor.b;
}

// ------------------------------------------ //

void main(void)
{
    mainImage(gl_FragColor, gl_FragCoord.xy);
//    gl_FragColor.r=1.;
}

