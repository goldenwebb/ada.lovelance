### 29402:S metallic402

// https://www.shadertoy.com/view/tffBzf

// Copyright
// 
// ------------------------------------------ //

precision highp float;

#define iTime CC_Time[0]*20.
#define iMouse vec3(0.)

uniform vec2 iResolution;
#define iResolution vec3(iResolution*2.,1024.)

#define texture(a,bbb) texture2D(a,bbb.xy)

uniform sampler2D iChannel0;

// COMMON [

//== Hash and Noise function ==//

float hash12(vec2 p) {
    vec3 p3  = fract(vec3(p.xyx) * 0.1031);
    p3 += dot(p3, p3.yzx + 33.33);
    return fract((p3.x + p3.y) * p3.z);
}

vec3 hash33(vec3 p) {
    p = fract(p * 0.1031);
    p += dot(p, p.yzx + 31.32);
    return fract((p.xxy + p.yxx) * p.zyx);
}

float tex3d_perlin(vec3 coord, float seed) {
    vec3 i = floor(coord);
    vec3 f = fract(coord);

    // Gradients at cube corners
    vec3 v000 = normalize(hash33(i + vec3(0,0,0) + seed) - 0.5);
    vec3 v001 = normalize(hash33(i + vec3(0,0,1) + seed) - 0.5);
    vec3 v010 = normalize(hash33(i + vec3(0,1,0) + seed) - 0.5);
    vec3 v011 = normalize(hash33(i + vec3(0,1,1) + seed) - 0.5);
    vec3 v100 = normalize(hash33(i + vec3(1,0,0) + seed) - 0.5);
    vec3 v101 = normalize(hash33(i + vec3(1,0,1) + seed) - 0.5);
    vec3 v110 = normalize(hash33(i + vec3(1,1,0) + seed) - 0.5);
    vec3 v111 = normalize(hash33(i + vec3(1,1,1) + seed) - 0.5);

    // Dot products
    float p000 = dot(v000, f - vec3(0,0,0));
    float p001 = dot(v001, f - vec3(0,0,1));
    float p010 = dot(v010, f - vec3(0,1,0));
    float p011 = dot(v011, f - vec3(0,1,1));
    float p100 = dot(v100, f - vec3(1,0,0));
    float p101 = dot(v101, f - vec3(1,0,1));
    float p110 = dot(v110, f - vec3(1,1,0));
    float p111 = dot(v111, f - vec3(1,1,1));

    // Quintic fade
    vec3 t = f*f*f*(f*(f*6.0 - 15.0) + 10.0);

    // Trilinear interpolation
    return mix(
        mix(mix(p000, p100, t.x), mix(p010, p110, t.x), t.y),
        mix(mix(p001, p101, t.x), mix(p011, p111, t.x), t.y),
        t.z
    ) * 0.5 + 0.5; // normalize to [0,1]
}

float fbm3d_perlin(vec3 coord, int octaves, float persistence, float seed) {
    float value = 0.0;
    float scale = 1.;
    float norm  = 0.0;

    for (int i = 0; i < octaves; i++) {
        value += tex3d_perlin(coord, seed) * scale;
        norm  += scale;
        coord *= 2.0;
        scale *= persistence;
    }

    return value / norm;
}

float warp3(vec3 p) {
    // first layer of fbm
    float f1 = fbm3d_perlin(p + vec3(0.0, 0.0, 0.0), 1, 0.5, 42.0);
    float f2 = fbm3d_perlin(p + vec3(5.2, 1.3, 7.1), 1, 0.5, 133.7);
    float f3 = fbm3d_perlin(p + vec3(-2.3, 4.7, 3.1), 1, 0.5, 99.9);

    // combine 
    vec3 q = vec3(f1, f2, f3);

    // warp the domain
    return fbm3d_perlin(q, 2, 2., 42.0);
}

// COMMON ]
// MAIN [

#define MAX_STEPS 100
#define MAX_DIST 100.
#define SURF_DIST .001
#define TWO_PI 6.283185
#define PI 3.141592
#define FOV 1.2

//2D rotation
mat2 rot2D(float angle){
    float s = sin(angle);
    float c = cos(angle);
    return mat2(c, -s, s, c);
}

// Sphere SDF
float sdSphere( vec3 p, float s){
    return length(p) - s;
}

// Distance to the scene
float map(vec3 p){
    
   // p += vec3(cos(iTime), sin(iTime * 2.0), 0.0); //floating motion
    
    p.xz *= rot2D((iTime * 2. + sin(.8 + iTime * 3.)) * 0.7);
    p.xy *= rot2D((iTime * 2. + sin(.8 + iTime * 3.)) * 0.5);
    
    float noise = fbm3d_perlin(p,8,.42,142.); // scale, octaves, persistence, seed
    float obj = sdSphere(p,1.+noise);  
    
    return obj;
}

//Raymarch
vec2 rayMarch(vec3 ro, vec3 rd, float side){
    float t = .0;
    float dM = MAX_DIST;
    
    for(int i = 0; i < MAX_STEPS; i++){
        vec3 p = ro + rd * t;
        float d = map(p)*side;
        
        if(d<dM) dM = d;
        t += d;
        
        if(t>MAX_DIST || abs(d)<SURF_DIST) break;
   
    }
    
    return vec2(t, dM);
}

vec3 getNormal(vec3 p) {
    vec2 e = vec2(.001, 0);
    vec3 n = map(p) - 
        vec3(map(p-e.xyy), map(p-e.yxy),map(p-e.yyx));
    
    return normalize(n);
}


vec3 getRayDir(vec2 uv, vec3 p, vec3 l, float z) {
    vec3 
        f = normalize(l-p),
        r = normalize(cross(vec3(0,1,0), f)),
        u = cross(f,r),
        c = f*z,
        i = c + uv.x*r + uv.y*u;
    return normalize(i);
}

float calcAO( in vec3 pos, in vec3 nor )
{
    float occ = 0.0;
    float sca = 1.0;
    for( int i=0; i<5; i++ )
    
    {
        float hr = 0.01 + 0.12*float(i)/4.0;
        vec3 aopos =  nor * hr + pos;
        float dd = map(aopos);
        occ += -(dd-hr)*sca;
        sca *= 0.95;
    }
    return clamp( 1.0 - 3.0*occ, 0.0, 1.0 );    
}

void mainImage( out vec4 fragColor, in vec2 fragCoord )
{   
    
    // Initialize
    vec2 m = iMouse.xy/iResolution.xy;
    vec3 col = vec3(.0);
    vec3 ro = vec3(0,0, -6); //ray origin
    
    // Mouse Controls
    vec2 rotation = vec2(iMouse.z > 0.0 ? -m.x*TWO_PI:0., iMouse.z > 0.0 ? -m.y*PI+1. : .0);
    
    ro.yz *= rot2D(rotation.y);
    ro.xz *= rot2D(rotation.x);
    
    vec2 uv = (fragCoord - .5*iResolution.xy)/iResolution.y;
    vec3 rd = getRayDir(uv, ro, vec3(0,0,0), FOV); //ray direction
    
    // Raymarch
    float d = rayMarch(ro,rd,1.).r; //total distance travelled
    vec3 p = ro + rd * d;
    
    float IOR = 1.44; //approximate fake not complex IOR
    
    if(d<MAX_DIST){

        vec3 n = getNormal(p);
        
        // Initialize material
        vec3 refl = reflect(rd,n);
        vec3 rayTex = .6 * texture(iChannel0, refl).rgb;
        
        vec3 refr = refract(rd,n,1./IOR);
        rayTex += .5 * texture(iChannel0, refr).rgb;
        
        col = rayTex; 
        
        // Lighting
        float occ = calcAO(p, n);
        vec3  l = normalize(vec3(-0.6, 0.7, -0.8));
        float amb = clamp(0.5+0.5*n.y, 0.0, 1.0);
        float dif = clamp(dot(n, l), 0.0, 1.0 );
        float bac = clamp(dot(n, normalize(vec3(-l.x,0.0,-l.z))), 0.0, 1.0)*clamp(1.0-p.y,0.0,1.0);
        float dom = smoothstep(-0.1, 0.1, rayTex.y);
        float fre = pow(clamp(1.0+dot(n,rd),0.0,1.0), 2.0);
        float spe = pow(clamp(dot(rayTex, l), 0.0, 1.0),16.0);
        
        // BRDF
        vec3 brdf = vec3(0.0);
        brdf += 1.1*dif*vec3(0.9,0.92,0.95);
        brdf += 1.1*spe*vec3(.9,0.92,0.95)*dif;
        brdf += 0.30*amb*vec3(0.50,0.70,1.00)*occ;
        brdf += 0.40*dom*vec3(0.50,0.70,1.00)*occ;
        brdf += 0.30*bac*vec3(0.25,0.25,0.25)*occ;
        brdf += 0.40*fre*vec3(1.00,1.00,1.00)*occ;
        brdf += .1;
        col *= brdf;
        col = pow(col, vec3(.4545));
        
    }
    else { 
    
        //Background
//        col = texture(iChannel0, rd).rgb;
        fragColor = vec4(0.);
        return;
        
    }

    // Output to screen
    fragColor = vec4(col, 1);
}


// MAIN ]

// ------------------------------------------ //

void main(void)
{
    mainImage(gl_FragColor, gl_FragCoord.xy);
}

