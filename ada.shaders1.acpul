### 29379:S dota.portal379

// https://www.shadertoy.com/view/wXfyDf

// Copyright
// 
// ------------------------------------------ //

precision highp float;

#define iTime CC_Time[0]*20.
#define iMouse vec2(0.)

uniform vec2 iResolution;
#define iResolution (iResolution*2.)

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord / iResolution.xy) * 2.0 - 1.0;
    uv.x *= iResolution.x / iResolution.y;
    
    float radius = length(uv);
    float angle = atan(uv.y, uv.x);

    float depth = 1.0 / radius;

    float fractal = 0.0;
    float scale = 1.0;
    
    for(int i = 0; i < 13; i++) {
        fractal += sin(angle * 6.0 * scale + depth * 3.0 + iTime * 2.0) * 0.5 / scale;
        scale *= 2.0;
    }
    
    float tunnel = fractal * exp(-radius * 3.0);
    
    float vanishingPoint = smoothstep(0.1, 0.0, radius);
    
    vec3 color = 0.5 + 0.5 * cos(iTime * 0.5 + depth + vec3(0, 2, 4));
    color = color * tunnel + vanishingPoint * vec3(1.0, 0.9, 0.5);
    
    color *= 1.5;
    
    fragColor = vec4(color, 1.0);
    fragColor *= 2.;
    fragColor.a = fragColor.r+fragColor.g+fragColor.b;
}

// ------------------------------------------ //

void main(void)
{
    mainImage(gl_FragColor, gl_FragCoord.xy);
}

